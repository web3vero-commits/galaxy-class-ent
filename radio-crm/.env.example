# Copy to .env.local and fill in. .env.local is gitignored.

# ── Auth (NextAuth / Google OAuth) ───────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs must include:
#   https://radio.galaxyclassent.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Restrict OAuth to this Workspace domain (rejects gmail.com etc.)
GOOGLE_WORKSPACE_DOMAIN=galaxyclassent.com

# Allowlist — comma-separated emails allowed to log in.
# Even within Workspace, only these accounts can use the CRM.
ALLOWED_USERS=michael_z@galaxyclassent.com,michelle@galaxyclassent.com,foleymon@gmail.com

# NextAuth session encryption — generate via: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Google Sheets (backend service account) ──────────────────────────────────
# Service account JSON — choose ONE form:
#   (a) Path on disk (preferred for local dev)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
#   (b) Inline JSON (for Vercel env vars where you can't mount files)
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Sheet ID for the CRM database (from the sheet URL)
GCE_RADIO_SHEET_ID=

# ── Optional features (add later) ────────────────────────────────────────────
# Twilio for click-to-call (Phase 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend for follow-up emails (already used by radio-outreach)
RESEND_API_KEY=
